---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import ChangelogList from '../components/ChangelogList.astro';
import LettaHero from '../components/LettaHero.astro';
import LettaFeatures from '../components/LettaFeatures.astro';
import Pathways from '../components/Pathways.astro';
import LatestBlog from '../components/LatestBlog.astro';
---

<StarlightPage frontmatter={{ title: 'SEOCHO | Ontology-Aligned Graph Memory', template: 'splash' }} hasSidebar={false}>
  <main class="landing-override min-h-screen w-full bg-black text-zinc-100 selection:bg-cyan-300/20">
    <LettaHero />
    <LettaFeatures />
    <Pathways />

    <section class="mx-auto grid w-full max-w-7xl gap-8 px-5 py-20 md:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="mb-3 text-sm font-medium uppercase text-amber-200/80">First useful run</p>
        <h2 class="seocho-display text-4xl font-semibold leading-tight text-white md:text-5xl">
          Start without a server.
        </h2>
        <p class="mt-5 max-w-xl text-base leading-7 text-zinc-400">
          The shortest SEOCHO path is local: define one ontology, add one piece
          of text, and ask one question. Move to the runtime only when another
          process needs shared HTTP access.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/docs/quickstart/" class="rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-black transition-colors hover:bg-zinc-200">Quickstart</a>
          <a href="/docs/python_sdk/" class="rounded-lg border border-white/15 px-4 py-2.5 text-sm font-semibold text-zinc-100 transition-colors hover:bg-white/10">Python SDK</a>
          <a href="/docs/runtime_deployment/" class="rounded-lg border border-white/10 px-4 py-2.5 text-sm font-semibold text-zinc-300 transition-colors hover:bg-white/5">Runtime</a>
        </div>
      </div>

      <div class="rounded-lg border border-white/10 bg-[#060606] p-5">
        <div class="mb-4 flex items-center justify-between border-b border-white/10 pb-3">
          <span class="text-sm font-medium text-zinc-200">copy-paste local path</span>
          <span class="text-xs text-zinc-500">Python</span>
        </div>
        <pre class="overflow-x-auto text-sm leading-6 text-zinc-300"><code>{`from seocho import Seocho, Ontology, NodeDef, RelDef, Property

ontology = Ontology(
    name="work",
    nodes={
        "Person": NodeDef(properties={"name": Property(str, unique=True)}),
        "Company": NodeDef(properties={"name": Property(str, unique=True)}),
    },
    relationships={
        "WORKS_AT": RelDef(source="Person", target="Company"),
    },
)

client = Seocho.local(ontology, llm="mara/MiniMax-M2.5")
client.add("Marie Curie worked at the University of Paris.")
print(client.ask("Where did Marie Curie work?"))`}</code></pre>
      </div>
    </section>

    <section class="border-y border-white/10 bg-[#050505]">
      <div class="mx-auto grid w-full max-w-7xl gap-5 px-5 py-16 md:grid-cols-3 md:px-8">
        <div class="rounded-lg border border-white/10 bg-black/35 p-5">
          <p class="text-sm font-medium uppercase text-cyan-200/80">1. Local</p>
          <h2 class="mt-3 text-xl font-semibold text-white">Prove the ontology</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-400">Use the embedded engine to check that your entity and relationship model is useful.</p>
        </div>
        <div class="rounded-lg border border-white/10 bg-black/35 p-5">
          <p class="text-sm font-medium uppercase text-amber-200/80">2. Data</p>
          <h2 class="mt-3 text-xl font-semibold text-white">Load real records</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-400">Bring files, records, or run specs into a graph target you can inspect and query.</p>
        </div>
        <div class="rounded-lg border border-white/10 bg-black/35 p-5">
          <p class="text-sm font-medium uppercase text-emerald-200/80">3. Runtime</p>
          <h2 class="mt-3 text-xl font-semibold text-white">Share with agents</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-400">Expose the same ontology-grounded graph contract through HTTP, traces, and policy checks.</p>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-5 py-20 md:px-8">
      <div class="mb-8 flex flex-col gap-4 border-b border-white/10 pb-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-3 text-sm font-medium uppercase text-cyan-200/80">Deepen the map</p>
          <h2 class="seocho-display text-4xl font-semibold text-white md:text-5xl">Read next</h2>
        </div>
        <a href="/docs/" class="text-sm font-semibold text-zinc-300 transition-colors hover:text-white">Open docs home</a>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <a href="/learn/" class="rounded-lg border border-white/10 bg-white/[0.03] p-5 transition-colors hover:bg-white/[0.06]">
          <h3 class="text-lg font-semibold text-white">Concept Guide</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">A one-page map of the vocabulary, modes, request flow, and code ownership.</p>
        </a>
        <a href="/docs/architecture/" class="rounded-lg border border-white/10 bg-white/[0.03] p-5 transition-colors hover:bg-white/[0.06]">
          <h3 class="text-lg font-semibold text-white">Architecture</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">The deeper module map for SDK, indexing, query, runtime, and compatibility layers.</p>
        </a>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-5 py-20 md:px-8">
      <div class="mb-8 flex items-end justify-between border-b border-white/10 pb-6">
        <div>
          <p class="mb-3 text-sm font-medium uppercase text-amber-200/80">Writing</p>
          <h2 class="seocho-display text-4xl font-semibold text-white md:text-5xl">Blog</h2>
          <p class="mt-2 text-sm text-zinc-500">Concepts, reasoning, and major release notes.</p>
        </div>
        <a href="/blog/" class="text-sm font-semibold text-zinc-300 transition-colors hover:text-white">All posts</a>
      </div>
      <LatestBlog />
    </section>

    <section class="mx-auto w-full max-w-6xl px-5 pb-24 md:px-8">
      <div class="mb-8 flex items-end justify-between border-b border-white/10 pb-6">
        <div>
          <p class="mb-3 text-sm font-medium uppercase text-cyan-200/80">Project signal</p>
          <h2 class="seocho-display text-3xl font-semibold text-white md:text-4xl">Latest updates</h2>
          <p class="mt-2 text-sm text-zinc-500">Release-linked updates from the public GitHub trail.</p>
        </div>
        <a href="https://github.com/TTEON/seocho/commits/main/" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-zinc-300 transition-colors hover:text-white">Commits</a>
      </div>
      <ChangelogList />
    </section>
  </main>
</StarlightPage>

<style>
:global(.sl-container) {
  max-width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
}

:global(.sl-markdown-content) {
  display: contents !important;
}
</style>
