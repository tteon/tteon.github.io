---
const signals = [
  ['Ontology', 'allowed shapes'],
  ['Graph', 'stored evidence'],
  ['Query', 'bounded retrieval'],
  ['Runtime', 'agent access'],
];
---

<section class="brand-hero relative isolate overflow-hidden border-b border-white/10 bg-[#030405]">
  <img
    src="/images/seocho-brand-graph.png"
    alt="Layered ontology, graph memory, and runtime visual for SEOCHO"
    class="brand-hero-image absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(3,4,5,0.98)_0%,rgba(3,4,5,0.9)_29%,rgba(3,4,5,0.44)_58%,rgba(3,4,5,0.68)_100%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(3,4,5,0.32),rgba(3,4,5,0.96)_93%)]"></div>

  <div class="relative z-10 mx-auto flex min-h-[88svh] w-full max-w-7xl flex-col justify-center px-5 pb-16 pt-28 md:px-8 lg:pt-32">
    <div class="max-w-3xl">
      <p class="brand-kicker mb-6 inline-flex items-center gap-3 text-xs font-semibold uppercase text-[var(--seocho-paper)]/85">
        <span class="brand-mark" aria-hidden="true"></span>
        Ontology-aligned memory OS
      </p>

      <h1 class="seocho-display max-w-4xl text-5xl font-semibold leading-none text-[var(--seocho-paper)] md:text-7xl">
        Memory that keeps its shape.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-zinc-300 md:text-xl">
        SEOCHO turns ontology, graph facts, semantic queries, and agent runtime
        into one contract. Teams can inspect what an agent knows, why it knows
        it, and which relationships it is allowed to use.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href="/learn/" class="brand-button brand-button-primary">
          Understand SEOCHO
        </a>
        <a href="/docs/quickstart/" class="brand-button brand-button-secondary">
          Run the quickstart
        </a>
        <a href="https://github.com/TTEON/seocho" target="_blank" rel="noopener noreferrer" class="brand-button brand-button-ghost">
          GitHub
        </a>
      </div>
    </div>

    <dl class="mt-16 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {signals.map(([label, value]) => (
        <div class="brand-signal">
          <dt class="text-[0.68rem] font-semibold uppercase text-zinc-500">{label}</dt>
          <dd class="mt-2 block text-sm font-semibold text-zinc-100 m-0">{value}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
