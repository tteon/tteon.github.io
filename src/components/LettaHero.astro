---
const coreSteps = [
  ['1', 'Define ontology', 'Name the entity and relationship types the graph should allow.'],
  ['2', 'Index data', 'Turn documents or records into graph facts with provenance.'],
  ['3', 'Ask questions', 'Resolve intent against ontology and graph evidence before answering.'],
];
---

<section class="w-full border-b border-white/10 bg-[#030303]">
  <div class="mx-auto grid min-h-[78vh] w-full max-w-7xl grid-cols-1 gap-12 px-5 pb-16 pt-28 md:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:pt-32">
    <div class="z-10">
      <p class="mb-5 text-sm font-medium uppercase text-cyan-200/80">
        Ontology-aligned graph memory for agents
      </p>

      <h1 class="seocho-display max-w-4xl text-5xl font-semibold leading-none text-white md:text-7xl">
        One ontology contract from raw data to agent answers.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-zinc-300 md:text-xl">
        SEOCHO helps agents build and query graph memory without letting schemas,
        prompts, runtime APIs, and evidence drift apart.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href="/learn/" class="inline-flex items-center justify-center rounded-lg bg-white px-5 py-3 text-sm font-semibold text-black transition-colors hover:bg-zinc-200">
          Read the concept guide
        </a>
        <a href="/docs/quickstart/" class="inline-flex items-center justify-center rounded-lg border border-white/15 px-5 py-3 text-sm font-semibold text-zinc-100 transition-colors hover:bg-white/10">
          Run the quickstart
        </a>
        <a href="/docs/apply_your_data/" class="inline-flex items-center justify-center rounded-lg border border-white/10 px-5 py-3 text-sm font-semibold text-zinc-300 transition-colors hover:bg-white/5 hover:text-white">
          Bring your data
        </a>
      </div>
    </div>

    <div class="z-10 grid gap-4">
      <div class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
        <div class="mb-4 flex items-center justify-between border-b border-white/10 pb-3">
          <span class="text-sm font-medium text-zinc-200">SEOCHO core loop</span>
          <span class="text-xs text-zinc-500">local -> runtime</span>
        </div>
        <div class="grid gap-3">
          {coreSteps.map(([number, title, body]) => (
            <div class="grid grid-cols-[2rem_1fr] gap-3 rounded-lg border border-white/8 bg-black/30 p-4">
              <div class="flex h-8 w-8 items-center justify-center rounded-md bg-white/10 text-sm font-semibold text-white">{number}</div>
              <div>
                <h2 class="text-base font-semibold text-white">{title}</h2>
                <p class="mt-1 text-sm leading-6 text-zinc-400">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="overflow-hidden rounded-lg border border-white/10 bg-black">
        <img
          src="/images/hero-graph.png"
          alt="Graph visualization showing connected concepts and evidence"
          class="h-auto w-full opacity-85"
        />
      </div>
    </div>
  </div>
</section>
