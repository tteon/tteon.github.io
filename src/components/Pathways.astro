---
const paths = [
  {
    number: '01',
    eyebrow: 'Understand',
    title: 'Read the map',
    description:
      'Start with the concept guide: ontology, graph memory, query path, runtime, and ownership.',
    href: '/learn/',
    cta: 'Concept guide',
  },
  {
    number: '02',
    eyebrow: 'Build',
    title: 'Create local memory',
    description:
      'Use Seocho.local(...) to define one ontology, add one fact, and ask one grounded question.',
    href: '/docs/quickstart/',
    cta: 'Quickstart',
  },
  {
    number: '03',
    eyebrow: 'Operate',
    title: 'Run the contract',
    description:
      'Move to the runtime when multiple agents need the same HTTP surface, traces, and policy checks.',
    href: '/docs/runtime_deployment/',
    cta: 'Runtime docs',
  },
  {
    number: '04',
    eyebrow: 'Contribute',
    title: 'Shape the project',
    description:
      'Use the public issue, release, community, and PR rules to keep changes small and reviewable.',
    href: '/docs/open_source_playbook/',
    cta: 'Playbook',
  },
];
---

<section class="border-y border-white/10 bg-[#07100d]">
  <div class="mx-auto w-full max-w-7xl px-5 py-20 md:px-8">
    <div class="mb-12 max-w-3xl">
      <p class="mb-3 text-xs font-semibold uppercase text-emerald-200/80">Product paths</p>
      <h2 class="seocho-display text-4xl font-semibold leading-tight text-[var(--seocho-paper)] md:text-5xl">
        Start from the work in front of you.
      </h2>
      <p class="mt-5 text-base leading-7 text-zinc-400">
        The site should not ask readers to decode the repository first. Each
        path names the job, the next page, and the part of SEOCHO it exercises.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {paths.map((path) => (
        <a href={path.href} class="brand-path group">
          <span class="text-xs font-semibold text-emerald-200/70">{path.number}</span>
          <p class="mt-6 text-[0.68rem] font-semibold uppercase text-zinc-500">{path.eyebrow}</p>
          <h3 class="mt-3 text-2xl font-semibold text-[var(--seocho-paper)]">{path.title}</h3>
          <p class="mt-4 min-h-[7rem] text-sm leading-6 text-zinc-400">{path.description}</p>
          <span class="mt-8 inline-flex text-sm font-semibold text-zinc-200 transition-colors group-hover:text-white">
            {path.cta}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
