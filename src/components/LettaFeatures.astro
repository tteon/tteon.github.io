---
const pillars = [
  {
    label: 'Contract',
    title: 'Ontology first',
    body: 'Define the entity and relationship vocabulary before agents start writing memory.',
    tone: 'cyan',
  },
  {
    label: 'Memory',
    title: 'Graph native',
    body: 'Persist facts, provenance, and constraints as relationships that can be inspected.',
    tone: 'emerald',
  },
  {
    label: 'Answer',
    title: 'Evidence bound',
    body: 'Route questions through ontology and graph context before response synthesis.',
    tone: 'amber',
  },
  {
    label: 'Runtime',
    title: 'Agent ready',
    body: 'Expose the same contract through SDK calls, HTTP endpoints, traces, and policy checks.',
    tone: 'ivory',
  },
];
---

<section class="bg-[var(--seocho-paper)] text-[#11110f]">
  <div class="mx-auto grid w-full max-w-7xl gap-10 px-5 py-20 md:px-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
    <div>
      <p class="mb-3 text-xs font-bold uppercase text-[#35635b]">Brand promise</p>
      <h2 class="seocho-display max-w-xl text-4xl font-semibold leading-tight text-[#11110f] md:text-5xl">
        A graph memory system with visible rules.
      </h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-[#4d4a43]">
        SEOCHO should feel closer to infrastructure than a demo app: compact,
        inspectable, and built around contracts that survive across local
        experiments, production runtimes, and open-source contribution.
      </p>
      <a href="/docs/why_seocho/" class="brand-link-dark mt-7 inline-flex">
        Why this exists
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {pillars.map((pillar) => (
        <article class={`brand-pillar brand-pillar-${pillar.tone}`}>
          <p class="text-[0.68rem] font-bold uppercase text-[#5b574e]">{pillar.label}</p>
          <h3 class="mt-5 text-2xl font-semibold text-[#11110f]">{pillar.title}</h3>
          <p class="mt-3 text-sm leading-6 text-[#5d594f]">{pillar.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
